@inject IDataService DataService

@if (dataLoaded)
{
    <div class="SkillDetailColumn">
        @foreach (var s in upgradeGroup!.Index())
        {
            <SkillWithMonsters skill=@(s.Item.Skill) isCurrent=@(s.Item.Skill.Id == currentSkill.Id) isRelevant=@(s.Item.Skill.Id == skill.Id) showMonsters=@(!upgradeGroup!.Any(combo => combo.Skill.Id == currentSkill.Id)) />
            @if (s.Index < upgradeGroup!.Length - 1)
            {
                <div class="Operator">↓</div>
            }
        }
    </div>
}

@code {
    [Parameter]
    public required Services.Skill skill { get; set; }

    [Parameter]
    public required Services.Skill currentSkill { get; set; }

    private bool dataLoaded => (upgradeGroup is not null && upgradeGroup.Length > 0);
    private Services.Combination[]? upgradeGroup;

    protected override async Task OnParametersSetAsync()
    {
        upgradeGroup = (await DataService.GetSkillsByUpgradeGroupAsync(skill.Name)) ?? [];
    }
}
